# Frontend runtime mode:
# - "false" => real backend + Firebase Auth flow
# - "true"  => local mock/demo mode with no live backend required
NEXT_PUBLIC_USE_MOCKS="false"

# Optional override for direct API calls. In local dev, Next rewrites usually make this unnecessary.
NEXT_PUBLIC_API_BASE_URL="/api/v1"

# FastAPI backend URL used by Next.js rewrites in local/dev mode.
BACKEND_URL="http://localhost:8000"

# Firebase Web SDK config for real auth mode.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Optional UI metadata.
APP_URL="http://localhost:3000"
