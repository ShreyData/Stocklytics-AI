APP_ENV=local
API_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=

# Firebase Auth config used by backend token verification.
# Local/dev:
#   Set these only if you want to use a raw service-account key from env vars.
# Cloud Run:
#   Prefer leaving FIREBASE_CLIENT_EMAIL and FIREBASE_PRIVATE_KEY blank and
#   granting the runtime service account Firebase Admin / Firestore / BigQuery access.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=

# Firestore / BigQuery / Gemini runtime config.
FIRESTORE_PROJECT_ID=
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET_RAW=stocklytics_raw
BIGQUERY_DATASET_MART=stocklytics_mart
GEMINI_API_KEY=
AI_PRIMARY_MODEL_ID=gemini-2.0-flash
AI_DEFAULT_MODEL_ID=gemini-2.0-flash
AI_FAST_MODEL_ID=gemini-2.0-flash
AI_REASONING_MODEL_ID=gemini-2.0-flash
AI_FALLBACK_MODEL_IDS=gemini-2.0-flash-lite-001
GEMINI_MODEL_FALLBACKS=gemini-2.0-flash-lite-001
GEMINI_MODEL_TIMEOUT_SECONDS=45
GEMINI_GENERATION_RETRIES=2
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
VECTOR_SEARCH_TOP_K=5
EMBEDDING_BATCH_SIZE=50

# E2E script config
BASE_URL=http://127.0.0.1:8000

# Use one of the auth modes below:
# 1. Real auth mode:
# TEST_BEARER_TOKEN=<firebase id token for an admin user>
# TEST_STORE_ID=<store_id from that user token>
#
# 2. Local stub auth mode:
# Leave FIREBASE_PROJECT_ID blank
# TEST_BEARER_TOKEN=dev-token
# TEST_STORE_ID=Demo_Shop
TEST_BEARER_TOKEN=dev-token
TEST_STORE_ID=Demo_Shop

# Optional values used by the E2E checker.
TEST_PAYMENT_METHOD=cash
TEST_CHAT_SESSION_ID=
TEST_CHAT_QUERY=Give me a short business summary for today.

# Optional toggles for deeper checks.
RUN_PIPELINE_CHECK=0
RUN_ANALYTICS_AI_CHECK=0
