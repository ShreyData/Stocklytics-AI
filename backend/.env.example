APP_ENV=local
API_PORT=8000
LOG_LEVEL=INFO

# Firebase Auth config used by backend token verification.
# Leave these blank only if you intentionally want local stub auth mode.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firestore / BigQuery / Gemini runtime config.
FIRESTORE_PROJECT_ID=
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET_RAW=stocklytics_raw
BIGQUERY_DATASET_MART=stocklytics_mart
GEMINI_API_KEY=

# E2E script config
BASE_URL=http://127.0.0.1:8000

# Use one of the auth modes below:
# 1. Real auth mode:
# TEST_BEARER_TOKEN=<firebase id token for an admin user>
# TEST_STORE_ID=<store_id from that user token>
#
# 2. Local stub auth mode:
# Leave FIREBASE_PROJECT_ID blank
# TEST_BEARER_TOKEN=dev-token
# TEST_STORE_ID=store_001
TEST_BEARER_TOKEN=dev-token
TEST_STORE_ID=store_001

# Optional values used by the E2E checker.
TEST_PAYMENT_METHOD=cash
TEST_CHAT_SESSION_ID=
TEST_CHAT_QUERY=Give me a short business summary for today.

# Optional toggles for deeper checks.
RUN_PIPELINE_CHECK=0
RUN_ANALYTICS_AI_CHECK=0
