APP_ENV: production
LOG_LEVEL: INFO
CORS_ALLOW_ORIGINS: https://YOUR_FRONTEND_HOST

FIREBASE_PROJECT_ID: YOUR_GCP_PROJECT_ID
FIRESTORE_PROJECT_ID: YOUR_GCP_PROJECT_ID
BIGQUERY_PROJECT_ID: YOUR_GCP_PROJECT_ID
BIGQUERY_DATASET_RAW: stocklytics_raw
BIGQUERY_DATASET_MART: stocklytics_mart

GEMINI_API_KEY: REPLACE_WITH_SECRET
GEMMA_MODEL_ID: gemini-2.0-flash
GEMINI_MODEL_FALLBACKS: gemini-2.0-flash-lite-001
GEMINI_MODEL_TIMEOUT_SECONDS: "45"
GEMINI_GENERATION_RETRIES: "2"
GEMINI_EMBEDDING_MODEL: gemini-embedding-001
VECTOR_SEARCH_TOP_K: "5"
EMBEDDING_BATCH_SIZE: "50"
