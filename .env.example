# Backend
APP_ENV=local
API_PORT=8000
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=

# Local GCP credentials for Firestore / BigQuery client libraries
# Point this to the downloaded service-account JSON file on your machine.
GOOGLE_APPLICATION_CREDENTIALS=

# Firebase / Auth
# Use the Firebase / GCP project that backs your store data.
FIREBASE_PROJECT_ID=
# From the same service-account JSON file used for Firebase Admin SDK auth.
FIREBASE_CLIENT_EMAIL=
# Keep this on one line with literal \n characters if storing in .env.
FIREBASE_PRIVATE_KEY=

# Firestore
# Usually the same project as FIREBASE_PROJECT_ID.
FIRESTORE_PROJECT_ID=

# BigQuery
# Usually the same GCP project. Create both datasets before pipeline testing.
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET_RAW=stocklytics_raw
BIGQUERY_DATASET_MART=stocklytics_mart

# Gemini
# Generate this from Google AI Studio for AI chat testing.
GEMINI_API_KEY=
GEMMA_MODEL_ID=gemini-2.0-flash
GEMINI_MODEL_FALLBACKS=gemini-2.0-flash-lite-001
GEMINI_MODEL_TIMEOUT_SECONDS=45
GEMINI_GENERATION_RETRIES=2
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
VECTOR_SEARCH_TOP_K=5
EMBEDDING_BATCH_SIZE=50
